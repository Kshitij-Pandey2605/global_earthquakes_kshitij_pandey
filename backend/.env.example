# Server Configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1

# MongoDB Configuration
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/global_earthquakes

# JWT Authentication
# Use a long random string (min 32 chars). Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7
JWT_REFRESH_SECRET=replace_with_another_long_random_secret_string
JWT_REFRESH_EXPIRE=7d

# CORS - Allowed frontend origins (comma-separated for multiple)
# Local:      http://localhost:5173,http://localhost:5174
# Production: https://your-app-name.netlify.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Rate Limiting
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
